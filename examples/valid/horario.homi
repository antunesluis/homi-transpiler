# Demonstra: TriggerHora (hora = HH:MM), ActionDesligar com domínio switch
# Desliga todas as luzes da sala em um horário fixo
automacao "Sala - desligar tudo" {
    quando hora = 05:00
    entao {
        desligar switch.luzes_da_sala
        desligar switch.luzes_da_cozinha
        desligar switch.luzes_do_lavabo
    }
}
